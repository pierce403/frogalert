#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
revision="${1:-}"
mode="${2:-}"

if [[ "$#" -gt 2 || "$revision" != "HARDWARE_REV1" ]]; then
  echo "usage: ./scripts/build-count-firmware HARDWARE_REV1 [--check]" >&2
  echo "Refusing a generic build: verify the opened PCB before choosing a revision." >&2
  exit 2
fi
if [[ -n "$mode" && "$mode" != "--check" ]]; then
  echo "usage: ./scripts/build-count-firmware HARDWARE_REV1 [--check]" >&2
  exit 2
fi

cd "$repo_root/firmware"
rust_tool="$repo_root/scripts/run-rust-toolchain"
env -u CARGO_TARGET_DIR \
  -u RUSTFLAGS \
  -u CARGO_ENCODED_RUSTFLAGS \
  -u CARGO_BUILD_RUSTFLAGS \
  -u CARGO_TARGET_RISCV32IMC_UNKNOWN_NONE_ELF_RUSTFLAGS \
  "$rust_tool" nightly-2026-07-17 cargo fmt --package frogalert-count-firmware --package frogalert-recovery -- --check
build_dir="$repo_root/tmp/build/frogalert-count"
env -u CARGO_TARGET_DIR \
  -u RUSTFLAGS \
  -u CARGO_ENCODED_RUSTFLAGS \
  -u CARGO_BUILD_RUSTFLAGS \
  -u CARGO_TARGET_RISCV32IMC_UNKNOWN_NONE_ELF_RUSTFLAGS \
  "$rust_tool" nightly-2026-07-17 cargo build \
  --locked \
  --target riscv32imc-unknown-none-elf \
  --target-dir "$build_dir" \
  --package frogalert-count-firmware \
  --bin frogalert-count-firmware \
  --release \
  --features hardware-rev1

elf="$build_dir/riscv32imc-unknown-none-elf/release/frogalert-count-firmware"
output_dir="$repo_root/tmp/firmware"
mkdir -p "$output_dir"
host="$("$rust_tool" nightly-2026-07-17 rustc -vV | sed -n 's/^host: //p')"
sysroot="$("$rust_tool" nightly-2026-07-17 rustc --print sysroot)"
llvm_bin="$sysroot/lib/rustlib/$host/bin"
disassembly="$output_dir/frogalert-count-HARDWARE_REV1.disassembly.txt"
elf_header="$("$llvm_bin/llvm-readobj" --file-headers "$elf")"
elf_attributes="$("$llvm_bin/llvm-readobj" --arch-specific "$elf")"
if ! grep -Eq '^Format: elf32-.*riscv$' <<<"$elf_header" ||
  ! grep -Eq '^[[:space:]]*Machine: EM_RISCV' <<<"$elf_header"; then
  echo "refusing artifact: expected an ELF32 RISC-V image" >&2
  exit 1
fi
arch_attribute="$(sed -n 's/^[[:space:]]*Value: \(rv32[^[:space:]]*\)$/\1/p' <<<"$elf_attributes" | head -n 1)"
if [[ -z "$arch_attribute" ]] ||
  ! grep -Eq 'rv32i' <<<"$arch_attribute" ||
  ! grep -Eq '_m[0-9]' <<<"$arch_attribute" ||
  ! grep -Eq '_c[0-9]' <<<"$arch_attribute" ||
  grep -Eq '_a[0-9]' <<<"$arch_attribute"; then
  echo "refusing artifact: expected atomic-free RISC-V IMC attributes" >&2
  echo "${arch_attribute:-missing RISC-V arch attribute}" >&2
  exit 1
fi
"$llvm_bin/llvm-objdump" -d --mattr=+a "$elf" >"$disassembly"
if grep -Eiq '(^|[[:space:]])(amo|lr\.|sc\.)' "$disassembly"; then
  echo "refusing artifact: QingKe-unsafe atomic instruction found" >&2
  exit 1
fi
recovery_disassembly="$(sed -n '/<frogalert_enter_rom_isp>:/,/^$/p' "$disassembly")"
if [[ -z "$recovery_disassembly" ]] ||
  ! grep -Eq '[[:space:]]jr[[:space:]]+zero([[:space:]]|$)|[[:space:]]jalr[[:space:]]+zero,[[:space:]]*zero,[[:space:]]*0([[:space:]]|$)' <<<"$recovery_disassembly"; then
  echo "refusing artifact: ROM-ISP recovery trampoline does not end in an absolute zero jump" >&2
  exit 1
fi
"$llvm_bin/llvm-size" "$elf"
echo "RISC-V attributes: $arch_attribute"
echo "instruction audit passed: no AMO/LR/SC operations"
echo "recovery audit passed: KEY2 trampoline jumps to absolute address zero"
bin="$output_dir/frogalert-count-HARDWARE_REV1.bin"
"$llvm_bin/llvm-objcopy" -O binary "$elf" "$bin"
node "$repo_root/scripts/finalize-firmware.mjs" "$bin"
sha256sum "$bin"
wc -c "$bin"
if [[ "$mode" == "--check" ]]; then
  echo "embedded link check passed: $elf"
  exit 0
fi

echo "UNVERIFIED BUILD ONLY: do not flash without the physical gates in docs/HARDWARE.md"
