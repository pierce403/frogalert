#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

./scripts/run-rust-toolchain stable cargo fmt --all -- --check
./scripts/run-rust-toolchain stable cargo clippy --workspace --all-targets -- -D warnings
./scripts/run-rust-toolchain stable cargo test --workspace
mkdir -p tmp/c-tests
cc -std=c11 -Wall -Wextra -Werror \
  -Ifirmware/fossasia-usbc \
  firmware/fossasia-usbc/frogalert-survey-core.c \
  tests/fossasia-survey-core.c \
  -o tmp/c-tests/fossasia-survey-core
tmp/c-tests/fossasia-survey-core
firmware_host="$(./scripts/run-rust-toolchain nightly-2026-07-17 rustc -vV | sed -n 's/^host: //p')"
(
  cd firmware
  ../scripts/run-rust-toolchain nightly-2026-07-17 cargo test \
    --locked \
    --target "$firmware_host" \
    --package frogalert-recovery
)
mkdir -p tmp/vector-audit
expect_vector_quarantine() {
  local label="$1"
  local forbidden_bin="$2"
  shift 2
  local log="tmp/vector-audit/$label.log"

  mkdir -p "${forbidden_bin%/*}"
  touch "$forbidden_bin"
  if "$@" >"$log" 2>&1; then
    echo "expected $label to be quarantined by the CH58x vector audit" >&2
    return 1
  fi
  if ! grep -Fq "CH58x vector audit failed" "$log"; then
    echo "$label failed for an unexpected reason:" >&2
    sed -n '1,200p' "$log" >&2
    return 1
  fi
  if ! grep -Fq "[external-section]" "$log" ||
    ! grep -Fq "[tmr0-vector-target]" "$log"; then
    echo "$label did not expose the known misplaced external table and TMR0 vector:" >&2
    sed -n '1,200p' "$log" >&2
    return 1
  fi
  if [[ -e "$forbidden_bin" ]]; then
    echo "$label left a flashable BIN after its vector audit failed: $forbidden_bin" >&2
    return 1
  fi
  echo "$label quarantine check passed: diagnostic ELF retained; no BIN emitted"
}

expect_vector_quarantine \
  pixel-walk-rev1 \
  tmp/firmware/frogalert-pixel-walk-HARDWARE_REV1.bin \
  ./scripts/build-display-bringup HARDWARE_REV1 --check
expect_vector_quarantine \
  pixel-walk-usbc \
  tmp/firmware/frogalert-pixel-walk-B1144C_250901_USB_C.bin \
  ./scripts/build-display-bringup B1144C_250901_USB_C --check
expect_vector_quarantine \
  count-rev1 \
  tmp/firmware/frogalert-count-HARDWARE_REV1.bin \
  ./scripts/build-count-firmware HARDWARE_REV1 --check
node --test tests/*.test.mjs
node scripts/assemble-site.mjs tmp/site-build

if command -v xmllint >/dev/null 2>&1; then
  xmllint --html --noout index.html flash/index.html
else
  echo "note: xmllint not installed; site structure tests still ran" >&2
fi

codex_root="${CODEX_HOME:-$HOME/.codex}"
validator="$codex_root/skills/.system/skill-creator/scripts/quick_validate.py"
if [[ -f "$validator" ]]; then
  for skill in skills/*; do
    python3 "$validator" "$skill"
  done
else
  echo "note: Codex skill validator not installed; Node contract tests still check skill frontmatter" >&2
fi

git diff --check
git diff --cached --check
